generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
  budgets   Budget[]
}

model Expense {
  id            String   @id @default(cuid())
  name          String
  amount        Float
  type          String
  category      String
  status        String   @default("cleared")
  date          DateTime
  note          String?
  paymentMethod String?
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Budget {
  id        String   @id @default(cuid())
  category  String
  limit     Float
  spent     Float    @default(0)
  month     Int
  year      Int
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}